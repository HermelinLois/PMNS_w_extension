void print_after_init_phipow(mp_limb_t vector[DEGREE][NB_LIMBS]) {
    printf("--- Sortie de init_element_times_phipow ---\n");
    mpz_t temp_z;
    mpz_init(temp_z);

    for (int deg = 0; deg < DEGREE; deg++) {
        // Importation des limbs dans un mpz pour affichage propre
        mpz_import(temp_z, NB_LIMBS, -1, sizeof(mp_limb_t), 0, 0, vector[deg]);
        
        gmp_printf("Coeff[%d] : %Zd\n", deg, temp_z);
    }
    
    mpz_clear(temp_z);
    printf("-------------------------------------------\n\n");
}


static inline void montgomery_reduction(mp_limb_t polynomial[DEGREE][NB_LIMBS]){
    int MAX_SIZE = NB_LIMBS + 1;
    mp_limb_t tmp_Q[DEGREE][NB_LIMBS];
    mp_limb_t tmp_T[DEGREE][MAX_SIZE];

    // 1. compute Q = Pol * mat_N % phi
    for (int j=0; j<DEGREE; j++) {
        unsigned __int128 acc = 0;
        for (int i = 0; i < DEGREE; i++) {
            acc += (unsigned __int128)polynomial[i][0] * (unsigned __int128)MAT_N[i][j];
        }
        uint64_t mod_phi = (uint64_t) acc;

        // Extension de signe de mod_phi sur NB_LIMBS
        tmp_Q[j][0] = mod_phi;
        mp_limb_t sign_fill = (mod_phi > LIMIT) ? (mp_limb_t)-1 : 0;
        for(int limb = 1; limb < NB_LIMBS; limb++) {
            tmp_Q[j][limb] = sign_fill;
        }   
    }

    // 2. compute T = Q * mat_M (Version signée robuste)
    for (int i = 0; i < DEGREE; i++) {
        mpn_zero(tmp_T[i], MAX_SIZE);

        for (int j = 0; j < DEGREE; j++){
            int64_t m = MAT_M[j][i];
            if (m == 0) continue;

            mp_limb_t prod[MAX_SIZE];
            mpn_zero(prod, MAX_SIZE);
            
            uint64_t abs_m = (m < 0) ? (uint64_t)(-m) : (uint64_t)m;
            int q_is_neg = (tmp_Q[j][NB_LIMBS-1] > LIMIT);

            // Multiplication : on multiplie tout le bloc Q par abs_m
            mp_limb_t cy = mpn_mul_1(prod, tmp_Q[j], NB_LIMBS, abs_m);
            prod[NB_LIMBS] = cy;

            // Correction pour la multiplication d'un nombre signé par un scalaire
            if (q_is_neg) {
                prod[NB_LIMBS] -= abs_m;
            }

            // Accumulation signée dans T
            if (m > 0) {
                mpn_add_n(tmp_T[i], tmp_T[i], prod, MAX_SIZE);
            } else {
                mpn_sub_n(tmp_T[i], tmp_T[i], prod, MAX_SIZE);
            }
        }
    }

    // 3. compute (Pol + T) / phi
    for (int i = 0; i < DEGREE; i++) {
        mp_limb_t res_full[MAX_SIZE + 1];
        
        // Extension de signe de polynomial[i] sur le limb NB_LIMBS
        mp_limb_t pol_hi = (polynomial[i][NB_LIMBS-1] > LIMIT) ? (mp_limb_t)-1 : 0;
        
        // Addition Pol + T
        mp_limb_t carry = mpn_add_n(res_full, tmp_T[i], polynomial[i], NB_LIMBS);
        
        // Le limb de poids fort (MSB) combine les signes et le carry
        res_full[NB_LIMBS] = tmp_T[i][NB_LIMBS] + pol_hi + carry; 

        // Division par Phi (décalage de 1 limb)
        for (int limb = 0; limb < NB_LIMBS - 1; limb++) {
            polynomial[i][limb] = res_full[limb + 1];
        }
        polynomial[i][NB_LIMBS - 1] = res_full[NB_LIMBS];
    }
}



void convert_element_to_pmns_classical(int64_t *out, mp_limb_t element_data[EXTENSION_DEGREE][NB_LIMBS]){
    mp_limb_t vector[DEGREE][NB_LIMBS];

    init_element_times_phipow(vector, element_data, NB_INTERN_RED_CALSSICAL);
    print_after_init_phipow(vector);

    element_change_basis(vector, vector);
    
    for (int it=0; it<NB_INTERN_RED_CALSSICAL; it++)
        montgomery_reduction(vector);

    for (int deg=0; deg<DEGREE; deg++)
        out[deg] = (int64_t) vector[deg][0];
}


void print_polynomial(int64_t *polynomial){
    for (int i=0; i<DEGREE; i++)
        printf("%ld, ", polynomial[i]);
    printf("\n\n");
}



int main() {
    int64_t polynomial[DEGREE];
    for (int i=0; i<N_TEST; i++){
        convert_element_to_pmns_classical(polynomial, EXTENSION_FIELD_ELEMENTS[i]);
        //print_polynomial(polynomial);
    }
    return 0;
}


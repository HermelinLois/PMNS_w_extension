#include <gmp.h>
#include <stdio.h>
#include "../add_parameters/general_param.h"
#include "../test_values/test_conversion.h"


static const mp_limb_t P[NB_LIMBS] = {
    9068848573518170987ULL, 14399738040882861814ULL, 3888443751371387486ULL, 
    9336030797012126529ULL, 15905188286534281569ULL, 18019520612220357679ULL, 
    5649735080571351357ULL, 12491794462784956816ULL
};
static const mp_limb_t TRANSITION_MATRIX[EXTENSION_DEGREE][EXTENSION_DEGREE][NB_LIMBS] ={
    {
        {1ULL, 0ULL, 0ULL, 0ULL, 0ULL, 0ULL, 0ULL, 0ULL}
    }
};

static const uint64_t LIMIT = 0x7FFFFFFFFFFFFFFFULL;


static inline void init_element_times_phipow(mp_limb_t out[DEGREE][NB_LIMBS], const mp_limb_t data[EXTENSION_DEGREE][NB_LIMBS], unsigned int power) {
    int total_limbs = NB_LIMBS + power;
    
    mp_limb_t temp_el[total_limbs];
    mp_limb_t quotient[power + 1];
    mp_limb_t remainder[NB_LIMBS];

    for (int deg = 0; deg < EXTENSION_DEGREE; deg++) {
        mpn_zero(temp_el, power);

        // write corresponding element
        for(int i = 0; i < NB_LIMBS; i++) 
            temp_el[power + i] = data[deg][i];

        // apply modulus p
        mpn_tdiv_qr(quotient, remainder, 0, temp_el, total_limbs, P, NB_LIMBS);
        mpn_copyi(out[deg], remainder, NB_LIMBS);
    }

    for (int deg = EXTENSION_DEGREE; deg < DEGREE; deg++) {
        mpn_zero(out[deg], NB_LIMBS);
    }
}



static inline void element_change_basis(mp_limb_t out[EXTENSION_DEGREE][NB_LIMBS], mp_limb_t extension_element[EXTENSION_DEGREE][NB_LIMBS]){
    int MAX_SIZE = 2 * NB_LIMBS + 2;

    mp_limb_t quotient[NB_LIMBS + 2];
    mp_limb_t remainder[NB_LIMBS];
    mp_limb_t acc[MAX_SIZE];
    mp_limb_t prod[MAX_SIZE];

    for (int j = 0; j < EXTENSION_DEGREE; j++){
        mpn_zero(acc, MAX_SIZE);
        mpn_zero(prod, MAX_SIZE);

        for (int i = 0; i < EXTENSION_DEGREE; i++){
            mpn_zero(prod, MAX_SIZE);
            mpn_mul_n(prod, extension_element[i], TRANSITION_MATRIX[i][j], NB_LIMBS);

            // Under the assumption EXTENSION_DEGREE < 2^64 and using the accumulator size bound,
            // the carry-out of this full-width addition is guaranteed to be zero.

            (void) mpn_add_n(acc, acc, prod, MAX_SIZE);
        }

        // Reduce accumulated result modulo P
        mpn_tdiv_qr(quotient, remainder, 0, acc, MAX_SIZE, P, NB_LIMBS);
        mpn_copyi(out[j], remainder, NB_LIMBS);
    }
}


